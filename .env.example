# Copy to .env (repo root — read by docker compose for ${...} interpolation).
# NEVER commit real secrets; .env is gitignored.

# Shared secret between the Nginx ACV Proxy and the backend (mTLS deployments).
# Both containers receive the same value; requests without it are rejected.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PROXY_SECRET=
