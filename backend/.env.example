# Copy to .env and fill. NEVER commit real secrets.
ACV_VERSION=1.0
# "dev" or "production". Production refuses to start with a placeholder or
# short (<32 chars) JWT_SECRET.
APP_ENV=dev
JWT_SECRET=change-me-dev-only
JWT_EXPIRE_SECONDS=1800
# Demo login password for the prototype (replace with a real auth scheme later).
DEMO_PASSWORD=acvp-demo

# --- TLS / mTLS (ACVP spec §6 ACV Proxy, §7 TLS 1.2+) -----------------------
# Enable when deploying behind the Nginx ACV Proxy.
TLS_ENABLED=false
MTLS_ENABLED=false
# Shared secret between the Nginx proxy and the backend.  Prevents attackers
# from bypassing TLS by connecting directly to uvicorn and forging headers.
# REQUIRED when MTLS_ENABLED=true (fail-closed: the server refuses to start
# with it missing, shorter than 16 chars, or set to a known placeholder).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PROXY_SECRET=

# --- Crypto boundary (NIST ACVP-Server GenVal) --------------------------------
# Leave USE_NIST_GENVAL=false to run against the vendored NIST fixtures (default,
# no .NET needed). Set true only after building the NIST GenValApp runner and
# starting Orleans — run scripts/nist/build-genval.sh then start-orleans.sh
# (it auto-clones our engine fork; see docs/nist-genval-integration.md).
USE_NIST_GENVAL=false
# Absolute path to the published NIST.CVP.ACVTS.Generation.GenValApp.dll
# GENVAL_RUNNER_DLL=/opt/nist-bin/genval-runner/NIST.CVP.ACVTS.Generation.GenValApp.dll
# Where per-vector-set work dirs are written (defaults to backend/data/acvp-sessions)
# GENVAL_ARTIFACT_ROOT=
GENVAL_TIMEOUT_SECONDS=120
